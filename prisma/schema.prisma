generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Submission {
  id          String   @id @default(cuid())
  email       String
  sessionId   String?
  totalScore  Int?
  maxScore    Int?
  completion  Int?
  scoreLevel    String?
  answers     Json
  result      Json
  submittedAt DateTime @default(now())
  session     AssessmentSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([email, submittedAt])
  @@index([sessionId, submittedAt])
  @@index([sessionId, totalScore])
  @@index([submittedAt])
}

model AssessmentSession {
  id         String       @id @default(cuid())
  code       String       @unique
  name       String
  ownerEmail String
  createdAt  DateTime     @default(now())
  submissions Submission[]

  @@index([ownerEmail, createdAt])
}
